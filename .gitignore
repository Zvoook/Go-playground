# --- Бинарные файлы и исполняемые файлы ---
# Локальные исполняемые файлы (компиляция без параметров)
*.exe
*.exe~
*.dll
*.so
*.dylib
# Скомпилированный бинарник (если вы называете его по имени папки)
/app
/main
/server

# --- Инструменты тестирования и профилирования ---
*.test
*.out
*.prof
# Файлы покрытия тестов
coverage.txt
coverage.html

# --- Зависимости (опционально) ---
# Исключайте vendor/ только если НЕ используете vendoring.
# Если хотите фиксировать зависимости в репозитории, удалите эту строку.
vendor/

# --- Локальные настройки и секреты ---
.env
.env.local
.env.*.local

# --- Локальные папки IDE и редакторов ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?